root = true

[*]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[{*.sh,*.bash,.bashrc,.bash_profile,.bash_login,.bash_logout,.profile,*.zsh,.zshrc,.zprofile,.zshenv,.zlogin,.zlogout}]
switch_case_indent = true
binary_next_line = false
space_redirects = true
keep_padding = false
indent_size = 2

[*.rs]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
