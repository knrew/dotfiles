{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "share": "disabled",
  "permission": {
    "bash": {
      "*": "ask",

      "ls*": "allow",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",
      "git reset*": "ask",
      "git stash*": "ask",

      "gh*": "ask",
      "gh --version*": "allow",
      "gh version*": "allow",
      "gh auth status*": "allow",
      "gh auth token*": "deny",
      "gh auth login*": "ask",
      "gh auth logout*": "ask",
      "gh auth refresh*": "ask",
      "gh repo view*": "allow",
      "gh repo list*": "allow",
      "gh pr list*": "allow",
      "gh pr view*": "allow",
      "gh pr status*": "allow",
      "gh pr diff*": "allow",
      "gh pr checks*": "allow",
      "gh issue list*": "allow",
      "gh issue view*": "allow",
      "gh issue status*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh run watch*": "allow",
      "gh workflow list*": "allow",
      "gh workflow view*": "allow",
      "gh release list*": "allow",
      "gh release view*": "allow",
      "gh label list*": "allow",
      "gh milestone list*": "allow",
      "gh search *": "allow",
      "gh api*": "ask",
      "gh repo create*": "ask",
      "gh repo clone*": "ask",
      "gh repo fork*": "ask",
      "gh repo edit*": "ask",
      "gh repo delete*": "deny",
      "gh repo archive*": "ask",
      "gh repo unarchive*": "ask",
      "gh repo rename*": "ask",
      "gh repo set-default*": "ask",
      "gh repo sync*": "ask",
      "gh pr create*": "ask",
      "gh pr checkout*": "ask",
      "gh pr comment*": "ask",
      "gh pr review*": "ask",
      "gh pr merge*": "ask",
      "gh pr close*": "ask",
      "gh pr edit*": "ask",
      "gh pr ready*": "ask",
      "gh pr reopen*": "ask",
      "gh pr update-branch*": "ask",
      "gh pr revert*": "ask",
      "gh issue create*": "ask",
      "gh issue comment*": "ask",
      "gh issue edit*": "ask",
      "gh issue close*": "ask",
      "gh issue reopen*": "ask",
      "gh issue delete*": "deny",
      "gh issue transfer*": "ask",
      "gh issue lock*": "ask",
      "gh issue unlock*": "ask",
      "gh issue pin*": "ask",
      "gh issue unpin*": "ask",
      "gh run cancel*": "ask",
      "gh run delete*": "deny",
      "gh run rerun*": "ask",
      "gh run download*": "ask",
      "gh workflow run*": "ask",
      "gh workflow enable*": "ask",
      "gh workflow disable*": "ask",
      "gh release create*": "ask",
      "gh release edit*": "ask",
      "gh release upload*": "ask",
      "gh release delete*": "deny",
      "gh release delete-asset*": "deny",
      "gh release download*": "ask",

      "sudo": "deny",
      "sudo *": "deny",
      "su": "deny",
      "su *": "deny"
    }
  }
}
